{
  "anime": {
    "name": "动漫/广播剧",
    "description": "自然口语，语气词丰富，适合动漫字幕。病娇/黑化/傲娇等角色语气有强烈情感表现力",
    "tone": "conversational",
    "use_honorifics": false,
    "contractions": true,
    "max_sentence_length": 25,
    "particles": ["嘛", "啊", "呀", "哦", "呢", "啦"],
    "rules": {
      "desu_masu": "simplify",
      "compound_sentences": "split",
      "repeated_deg": "merge",
      "add_emotional_particles": true,
      "use_slang": true
    },
    "system_prompt_suffix": "病娇角色语气要有压迫感、执念感、扭曲感。傲娇角色要有口是心非的感觉。",
    "example": {
      "ja": "おはよう、よく眠れた？",
      "zh": "早啊，睡得好么？"
    }
  },
  "drama": {
    "name": "影视剧",
    "description": "正式自然，保持原有节奏和语气。适合日剧、电影等真人影视作品",
    "tone": "natural",
    "use_honorifics": true,
    "contractions": false,
    "max_sentence_length": 30,
    "particles": ["呢", "啊", "吧"],
    "rules": {
      "desu_masu": "preserve",
      "compound_sentences": "keep",
      "repeated_deg": "keep",
      "add_emotional_particles": false,
      "use_slang": false
    },
    "system_prompt_suffix": "保持原文的情感层次和人物性格，不要添加额外语气词。",
    "example": {
      "ja": "おはようございます、よく眠れましたか？",
      "zh": "早上好，睡得好吗？"
    }
  },
  "youtube": {
